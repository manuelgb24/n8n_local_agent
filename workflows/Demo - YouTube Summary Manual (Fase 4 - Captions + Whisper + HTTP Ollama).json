    {
      "parameters": {
        "jsCode": "function fixMojibake(text) {\n  const t = String(text ?? '');\n  if (!t) return '';\n  if (!/(\\u00C3|\\u00C2|\\u00E2)/.test(t)) return t;\n\n  try {\n    return Buffer.from(t, 'latin1').toString('utf8');\n  } catch {\n    return t;\n  }\n}\n\nconst youtubeUrl = String($node['Set - Input YouTube URL'].json.youtubeUrl || '');\nconst videoId = String($node['Code - Extract Video ID'].json.videoId || '');\n\nconst items = $input.all();\nconst out = [];\n\nfor (const item of items) {\n  const data = item.json || {};\n\n  const whisperText = fixMojibake(data.transcriptText).trim();\n  if (whisperText) {\n    const transcriptText = whisperText.replace(/\\s+/g, ' ').trim();\n    if (transcriptText) {\n      out.push({ json: { youtubeUrl, videoId, transcriptText } });\n    }\n    continue;\n  }\n\n  const raw = String(\n    data.stdout ??\n    data.body ??\n    data.data ??\n    data.response ??\n    ''\n  ).replace(/\\r/g, '');\n\n  if (!raw.trim()) continue;\n\n  const lines = raw.split('\\n');\n  const cleanedLines = [];\n  let prev = '';\n\n  for (const line of lines) {\n    const t = line.trim();\n    if (!t) continue;\n    if (t === 'WEBVTT') continue;\n    if (/^\\d+$/.test(t)) continue;\n    if (/^\\d{2}:\\d{2}:\\d{2}\\.\\d{3}\\s+-->\\s+\\d{2}:\\d{2}:\\d{2}\\.\\d{3}/.test(t)) continue;\n\n    const normalized = t\n      .replace(/&amp;/g, '&')\n      .replace(/&lt;/g, '<')\n      .replace(/&gt;/g, '>')\n      .replace(/&quot;/g, '\"')\n      .replace(/&#39;/g, \"'\");\n\n    if (normalized === prev) continue;\n    prev = normalized;\n    cleanedLines.push(normalized);\n  }\n\n  const transcriptText = fixMojibake(cleanedLines.join(' ')).replace(/\\s+/g, ' ').trim();\n  if (transcriptText) {\n    out.push({ json: { youtubeUrl, videoId, transcriptText } });\n  }\n}\n\nreturn out;"
      },
