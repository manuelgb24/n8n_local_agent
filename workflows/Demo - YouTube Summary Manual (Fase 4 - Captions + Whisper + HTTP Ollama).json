    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const html = String($json.body ?? $json.data ?? $json.response ?? '').trim();\nconst youtubeUrl = String($node['Set - Input YouTube URL'].json.youtubeUrl || '');\nconst videoId = String($node['Code - Extract Video ID'].json.videoId || '');\n\nfunction extractPlayerResponse(page) {\n  const marker = 'ytInitialPlayerResponse = ';\n  const idx = page.indexOf(marker);\n  if (idx === -1) return null;\n\n  const start = idx + marker.length;\n  let depth = 0;\n  let inString = false;\n  let escaped = false;\n  let end = -1;\n\n  for (let i = start; i < page.length; i++) {\n    const ch = page[i];\n    if (inString) {\n      if (escaped) escaped = false;\n      else if (ch === '\\\\') escaped = true;\n      else if (ch === '\"') inString = false;\n      continue;\n    }\n\n    if (ch === '\"') {\n      inString = true;\n      continue;\n    }\n\n    if (ch === '{') {\n      depth++;\n      continue;\n    }\n\n    if (ch === '}') {\n      depth--;\n      if (depth === 0) {\n        end = i + 1;\n        break;\n      }\n    }\n  }\n\n  if (end === -1) return null;\n\n  try {\n    return JSON.parse(page.slice(start, end));\n  } catch {\n    return null;\n  }\n}\n\nfunction toVtt(url) {\n  if (!url) return '';\n  try {\n    const u = new URL(url);\n    u.searchParams.set('fmt', 'vtt');\n    return u.toString();\n  } catch {\n    return '';\n  }\n}\n\nfunction scoreTrack(track, lang) {\n  const lc = String(track?.languageCode || '').toLowerCase();\n  const isAuto = String(track?.kind || '').toLowerCase() === 'asr';\n\n  let score = 0;\n  if (lc === lang) score += 100;\n  else if (lc.startsWith(lang + '-')) score += 90;\n  else if (lc.includes(lang)) score += 70;\n\n  if (!isAuto) score += 20;\n  return score;\n}\n\nconst player = extractPlayerResponse(html);\nconst tracks = player?.captions?.playerCaptionsTracklistRenderer?.captionTracks || [];\n\nconst esTrack = tracks\n  .filter((t) => scoreTrack(t, 'es') > 0)\n  .sort((a, b) => scoreTrack(b, 'es') - scoreTrack(a, 'es'))[0];\n\nconst enTrack = tracks\n  .filter((t) => scoreTrack(t, 'en') > 0)\n  .sort((a, b) => scoreTrack(b, 'en') - scoreTrack(a, 'en'))[0];\n\nreturn {\n  youtubeUrl,\n  videoId,\n  esTrackUrlVtt: toVtt(esTrack?.baseUrl),\n  enTrackUrlVtt: toVtt(enTrack?.baseUrl)\n};"
      },
