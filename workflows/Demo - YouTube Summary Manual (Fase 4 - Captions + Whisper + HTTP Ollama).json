      "id": "10",
      "name": "Set - Build Summarization Prompt",
      "type": "n8n-nodes-base.set",
      "position": [
        2272,
        288
      ],
      "typeVersion": 3.4
    },
    {
      "parameters": {
        "jsCode": "function fixMojibake(text) {\n  const t = String(text ?? '');\n  if (!t) return '';\n  if (!/(\\u00C3|\\u00C2|\\u00E2)/.test(t)) return t;\n  try {\n    return Buffer.from(t, 'latin1').toString('utf8');\n  } catch {\n    return t;\n  }\n}\n\nfunction esc(s) {\n  return String(s)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;');\n}\n\nfunction toPrettyHtml(summaryText) {\n  const lines = summaryText\n    .split('\\n')\n    .map((l) => l.trim())\n    .filter((l) => l.length > 0);\n\n  if (!lines.length) return '';\n\n  const parts = [];\n  let inList = false;\n\n  for (const line of lines) {\n    const isBullet = /^[-*.]\\s+/.test(line);\n\n    if (isBullet) {\n      if (!inList) {\n        parts.push('<ul style=\"margin:0 0 14px 20px;padding:0;line-height:1.6;\">');\n        inList = true;\n      }\n      const content = line.replace(/^[-*.]\\s+/, '');\n      parts.push('<li style=\"margin:0 0 8px 0;\">' + esc(content) + '</li>');\n      continue;\n    }\n\n    if (inList) {\n      parts.push('</ul>');\n      inList = false;\n    }\n\n    parts.push('<p style=\"margin:0 0 12px 0;line-height:1.65;\">' + esc(line) + '</p>');\n  }\n\n  if (inList) {\n    parts.push('</ul>');\n  }\n\n  return parts.join('');\n}\n\nconst youtubeUrl = String($node['Set - Build Summarization Prompt'].json.youtubeUrl || '');\nconst videoId = String($node['Set - Build Summarization Prompt'].json.videoId || '');\n\nconst items = $input.all();\nconst out = [];\n\nfor (const item of items) {\n  const j = item.json || {};\n\n  const raw = [\n    j.response,\n    j.output,\n    j.text,\n    j.completion,\n    j.data?.response,\n    j.body?.response,\n    j.message?.content,\n  ].find((v) => typeof v === 'string' && v.trim().length > 0);\n\n  if (!raw) continue;\n\n  const summary = fixMojibake(String(raw).replace(/\\r/g, '').trim());\n  if (!summary) continue;\n\n  const summaryHtml = toPrettyHtml(summary);\n  if (!summaryHtml) continue;\n\n  out.push({\n    json: {\n      youtubeUrl,\n      videoId,\n      summary,\n      summaryHtml\n    }\n  });\n}\n\nreturn out;"
      },
